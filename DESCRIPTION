Package: lamaplot.context
Type: Package
Title: LamaPlotContext for enhanced graphs and data analysis
Version: 0.1.0
Authors@R: 
    c(
      person("Mathilde", "Lafay", email = "mathildelafay.v1@gmail.com", role = c("aut", "cre")),
      person("Clara", "Noël", email = "clara.noel.2@ulaval.ca", role = "aut")
